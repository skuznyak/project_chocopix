PORT=3000
NODE_ENV=development
# Comma-separated allow-list, e.g. http://localhost:5173,https://chocopix.store
# In production, leave empty only if you intentionally want to allow all origins.
CORS_ORIGIN=http://localhost:5173
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=ChocoPix Shop
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
ORDER_NOTIFICATION_EMAILS=orders@example.com,owner@example.com
