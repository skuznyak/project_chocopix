generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String      @id @default(cuid())
  slug             String      @unique
  name             String
  shortDescription String
  description      String
  composition      String[]
  weight           Int
  flavor           String
  price            Int
  previousPrice    Int?
  badge            String?
  category         String
  tags             String[]
  popularity       Int         @default(0)
  featured         Boolean     @default(false)
  images           ProductImage[]
}

model ProductImage {
  id        String  @id @default(cuid())
  src       String
  alt       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  fullName      String
  phone         String
  email         String?
  city          String
  branch        String
  address       String?
  deliveryMethod String
  estimatedDate DateTime
  paymentMethod String
  status        String      @default("pending")
  promoCode     String?
  total         Int
  createdAt     DateTime    @default(now())
  items         OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  quantity  Int
}
